---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Matthew Brownrigg — Designer & Engineer' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: same triad as Neo Mirai reference -->
    <!-- Chakra Petch (geometric display) · Zen Old Mincho (editorial serif body) · Azeret Mono (labels/metadata) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@400;500&family=Chakra+Petch:wght@300;400;500;600&family=Zen+Old+Mincho:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
