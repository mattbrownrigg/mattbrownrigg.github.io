---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Plate from '../../components/Plate.astro';
import Contours from '../../components/Contours.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort(
    (a, b) => a.data.order - b.data.order,
  );
  return projects.map((project, i) => ({
    params: { slug: project.id },
    props: {
      project,
      prev: i > 0 ? projects[i - 1] : null,
      next: i < projects.length - 1 ? projects[i + 1] : null,
    },
  }));
}

const { project, prev, next } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const num = String(data.order).padStart(2, '0');
const hasLink = Boolean(data.link && data.link.href !== '#');
---

<Layout
  title={`${data.shortTitle ?? data.title} — Matthew Brownrigg`}
  description={data.blurb}
>
  <SiteNav current="work" />

  <main class="case">
    <a href="/work" class="case-back">← Work</a>

    <header class="case-head">
      <Contours class="case-contours" rings={8} baseR={28} gap={28} />
      <div class="case-head-inner">
        <p class="case-num">
          #{num}
          {data.draft && <span class="case-draft">Draft</span>}
        </p>
        <h1 class="case-title">{data.title}</h1>
        <div class="case-rule" aria-hidden="true"></div>
        <p class="case-summary">{data.summary}</p>

        <dl class="case-facts">
          <div class="case-fact">
            <dt>Field</dt>
            <dd>{data.category}</dd>
          </div>
          <div class="case-fact">
            <dt>Year</dt>
            <dd>{data.year}</dd>
          </div>
          {
            data.role && (
              <div class="case-fact">
                <dt>Role</dt>
                <dd>{data.role}</dd>
              </div>
            )
          }
          {
            data.stack.length > 0 && (
              <div class="case-fact case-fact--wide">
                <dt>Built with</dt>
                <dd>{data.stack.join(' · ')}</dd>
              </div>
            )
          }
        </dl>

        {
          hasLink ? (
            <a
              href={data.link!.href}
              class="case-cta"
              rel="noopener noreferrer"
            >
              {data.link!.label}
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                <path
                  d="M2 6.5h9M7 2.5l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ) : (
            <p class="case-cta-pending">Link coming soon</p>
          )
        }
      </div>
    </header>

    {
      project.body?.trim() && (
        <div class="case-prose">
          <Content />
        </div>
      )
    }

    {
      data.screenshots.length > 0 && (
        <section class="case-plates" aria-label="Screenshots">
          {data.screenshots.map((shot, i) => (
            <Plate
              caption={shot.caption}
              src={shot.src}
              index={i}
              eager={i === 0}
            />
          ))}
        </section>
      )
    }

    <nav class="case-pager" aria-label="More projects">
      {
        prev ? (
          <a href={`/work/${prev.id}`} class="case-pager-link case-pager-prev">
            <span class="case-pager-dir">← Prev</span>
            <span class="case-pager-name">{prev.data.shortTitle ?? prev.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a href={`/work/${next.id}`} class="case-pager-link case-pager-next">
            <span class="case-pager-dir">Next →</span>
            <span class="case-pager-name">{next.data.shortTitle ?? next.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </main>

  <SiteFooter />
</Layout>
